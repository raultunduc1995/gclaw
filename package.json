{
  "name": "gclaw",
  "version": "1.0.0",
  "description": "A lightweight, high-performance TypeScript boilerplate for the Google GenAI SDK with parallel multi-group concurrency and clean tool-loops.",
  "main": "dist/index.js",
  "type": "module",
  "keywords": [
    "gemini",
    "google-genai",
    "agent",
    "concurrency",
    "typescript",
    "boilerplate",
    "mcp",
    "bot",
    "telegram",
    "bash",
    "text-editor"
  ],
  "author": "Tunduc Raul & Gemini Flash 3.5",
  "license": "MIT",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@google/genai": "2.8.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@js-temporal/polyfill": "^0.5.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^12.10.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.41.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  }
}
