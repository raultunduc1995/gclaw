# Google GenAI API Key (Get it from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (Get it from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini Model Selection (e.g., gemini-3.5-flash, gemini-2.5-pro, etc.)
GEMINI_MODEL=gemini-3.1-pro-preview

# Active Tools (Comma-separated list of enabled tools in /src/tools)
# Available by default: bash, text-editor
ENABLED_TOOLS=bash,text_editor,fetch_url_context

# Pino log level
LOG_LEVEL=debug

# WARNING: NODE_ENV controls third-party library optimizations.
# It should ONLY be set to "development", "production", or "test". 
# Never use custom values like "staging" or "qa", or dependencies will run unoptimized.
NODE_ENV=development
